# ── Auth ───────────────────────────────────────────────────────────────────

# Shared secret the glasses app must send as ?token= in the WebSocket URL.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WS_TOKEN=

# Port the WebSocket server listens on.
PORT=8787

# ── STT provider ────────────────────────────────────────────────────────────
# Choose 'local' (faster-whisper-server) or 'google' (Google Cloud STT)
STT_PROVIDER=local

# --- local STT: faster-whisper-server ---
# Run with Docker: docker run --gpus all -p 8000:8000 -e WHISPER__MODEL=large-v3 fedirz/faster-whisper-server:latest-cuda
WHISPER_URL=http://localhost:8000
WHISPER_MODEL=Systran/faster-whisper-large-v3

# --- Google STT ---
# Authentication uses Application Default Credentials (gcloud auth application-default login)
# OR point to a service account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── LLM provider ────────────────────────────────────────────────────────────
# Choose 'openai' (any OpenAI-compatible endpoint: Ollama, LM Studio, OpenAI, etc.)
# or 'anthropic' (Anthropic Claude API)
LLM_PROVIDER=openai

# --- OpenAI-compatible LLM ---
# Ollama (local):
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=gemma3:27b

# Real OpenAI (uncomment and update):
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
