# Port the WebSocket server listens on. The glasses app connects to this.
PORT=8787

# Shared secret — must match ?token= in the glasses app VITE_BACKEND_URL.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WS_TOKEN=

# URL of the local faster-whisper-server instance (speech-to-text).
# Default: http://localhost:8000
WHISPER_URL=http://localhost:8000

# Model name served by faster-whisper-server.
# Must match the model you passed to docker run / uvicorn.
WHISPER_MODEL=Systran/faster-whisper-large-v3

# URL of the local Ollama instance (reply suggestions).
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Ollama model tag to use for suggestions. Run `ollama list` to see available tags.
OLLAMA_MODEL=gemma3:27b
