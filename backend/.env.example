# Anthropic API key, used to generate reply suggestions.
ANTHROPIC_API_KEY=

# Path to a Google Cloud service account JSON key with Speech-to-Text access.
# https://cloud.google.com/speech-to-text/docs/before-you-begin
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Port the WebSocket server listens on. The glasses app connects to this.
PORT=8787
